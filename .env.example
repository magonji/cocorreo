# Copy to .env and adjust for the server. docker-compose.yml reads these variables.

# Directory with the already-imported cocorreo.db + attachments/ + .cocorreo-config.json.
COCORREO_DATA_DIR=./data

# Plain-text file (mode 600) with the encryption passphrase.
COCORREO_PASSPHRASE_FILE=./secrets/passphrase.txt

# Host port where the frontend is exposed.
COCORREO_WEB_PORT=8443

# GHCR namespace the prebuilt images are published to by the GitHub Actions
# workflow (.github/workflows/docker-publish.yml) — normally
# ghcr.io/<your-github-username-or-org>. Must match github.repository_owner
# for the workflow's tags to resolve to the same images `docker compose pull` fetches.
GHCR_NAMESPACE=ghcr.io/yourusername
