# Copia a .env y ajusta según el servidor. docker-compose.yml lee estas variables.

# Directorio con cocorreo.db + attachments/ + .cocorreo-config.json ya importado.
COCORREO_DATA_DIR=./data

# Archivo de texto plano (permisos 600) con la passphrase de cifrado.
COCORREO_PASSPHRASE_FILE=./secrets/passphrase.txt

# Puerto del host donde se expone el frontend.
COCORREO_WEB_PORT=8443
